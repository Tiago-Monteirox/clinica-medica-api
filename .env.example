# ============================================================
# Template de variáveis de ambiente — copie para .env e ajuste
# NUNCA commite o .env (já está no .gitignore)
# ============================================================

# ── JWT ──────────────────────────────────────────────────────
# Gere com: openssl rand -base64 64
JWT_SECRET=dev-secret-please-change-in-production-with-256-bits-minimum

# ── JPA ──────────────────────────────────────────────────────
# false em produção, true para debug local
JPA_SHOW_SQL=false

# ── JVM ──────────────────────────────────────────────────────
JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -Djava.security.egd=file:/dev/./urandom
