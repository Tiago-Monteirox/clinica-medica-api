# ============================================================
# .env.homologation.example
# ------------------------------------------------------------
# Template de homologation. Copie para .env.homologation e use:
#
#   docker compose --env-file .env.homologation \
#     -f docker-compose.yml -f docker-compose.homologation.yml \
#     up --build -d
#
# NÃO commite o .env.homologation real (já está no .gitignore).
# ============================================================

# ── Identificação do projeto Compose ────────────────────────
COMPOSE_PROJECT_NAME=clinica-homologation

# ── Portas no host ──────────────────────────────────────────
GATEWAY_HOST_PORT=8084
MYSQL_HOST_PORT=3307

# Dozzle (overlay opcional docker-compose.tools.yml).
# HOM usa 9998 para manter 9999 livre quando hom + prod rodam em paralelo.
DOZZLE_HOST_PORT=9998

# ── JWT ─────────────────────────────────────────────────────
# Para gerar um segredo forte: openssl rand -base64 64
JWT_SECRET=dev-secret-please-change-in-production-with-256-bits-minimum

# ── JPA ─────────────────────────────────────────────────────
JPA_SHOW_SQL=true

# ── JVM ─────────────────────────────────────────────────────
JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -Djava.security.egd=file:/dev/./urandom

# ── Bancos (todos no MySQL local do overlay) ────────────────
# Host = "mysql" (nome do serviço dentro da rede clinica-net).
# 1 MySQL com 3 schemas inicializados via sql/init.sql.
ADMIN_DB_URL=jdbc:mysql://mysql:3306/clinica_administrativo?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=America/Sao_Paulo
ADMIN_DB_USER=root
ADMIN_DB_PASSWORD=

AGENDAMENTO_DB_URL=jdbc:mysql://mysql:3306/clinica_agendamento?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=America/Sao_Paulo
AGENDAMENTO_DB_USER=root
AGENDAMENTO_DB_PASSWORD=

ATENDIMENTO_DB_URL=jdbc:mysql://mysql:3306/clinica_atendimento?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=America/Sao_Paulo
ATENDIMENTO_DB_USER=root
ATENDIMENTO_DB_PASSWORD=
