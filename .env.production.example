# ============================================================
# .env.production.example
# ------------------------------------------------------------
# Template de produção. Copie para .env.production e preencha
# com os endpoints e credenciais reais dos bancos externos.
#
#   docker compose --env-file .env.production \
#     -f docker-compose.yml -f docker-compose.production.yml \
#     up --build -d
#
# REGRAS:
#  - NÃO commite o .env.production real (já está no .gitignore).
#  - Use um secret manager (AWS SM, GCP SM, HashiCorp Vault)
#    para JWT_SECRET e *_DB_PASSWORD em produção real;
#    aqui ficam apenas placeholders.
#  - Cada serviço tem usuário/senha próprios — princípio do
#    menor privilégio entre microsserviços.
# ============================================================

# ── Identificação do projeto Compose ────────────────────────
COMPOSE_PROJECT_NAME=clinica-production

# ── Porta no host ───────────────────────────────────────────
# Gateway é a ÚNICA entrada pública.
GATEWAY_HOST_PORT=8080

# ── JWT ─────────────────────────────────────────────────────
# Gere com: openssl rand -base64 64
# JAMAIS use o segredo de homologation aqui.
JWT_SECRET=CHANGE_ME_TO_REAL_SECRET_FROM_SECRET_MANAGER

# ── JPA ─────────────────────────────────────────────────────
JPA_SHOW_SQL=false

# ── JVM ─────────────────────────────────────────────────────
JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -Djava.security.egd=file:/dev/./urandom

# ── Banco administrativo (externo) ──────────────────────────
ADMIN_DB_URL=jdbc:mysql://db-administrativo.internal:3306/clinica_administrativo?useSSL=true&serverTimezone=America/Sao_Paulo
ADMIN_DB_USER=svc_administrativo
ADMIN_DB_PASSWORD=CHANGE_ME_FROM_SECRET_MANAGER

# ── Banco agendamento (externo) ─────────────────────────────
AGENDAMENTO_DB_URL=jdbc:mysql://db-agendamento.internal:3306/clinica_agendamento?useSSL=true&serverTimezone=America/Sao_Paulo
AGENDAMENTO_DB_USER=svc_agendamento
AGENDAMENTO_DB_PASSWORD=CHANGE_ME_FROM_SECRET_MANAGER

# ── Banco atendimento (externo) ─────────────────────────────
ATENDIMENTO_DB_URL=jdbc:mysql://db-atendimento.internal:3306/clinica_atendimento?useSSL=true&serverTimezone=America/Sao_Paulo
ATENDIMENTO_DB_USER=svc_atendimento
ATENDIMENTO_DB_PASSWORD=CHANGE_ME_FROM_SECRET_MANAGER
