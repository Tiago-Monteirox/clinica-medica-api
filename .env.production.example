# ============================================================
# .env.production.example
# ------------------------------------------------------------
# Configuração de produção LOCAL deste trabalho integrador:
# 3 containers MySQL dedicados (database-per-service real),
# cada um com seu usuário próprio e senha fixa.
#
# Uso:
#   cp .env.production.example .env.production
#   docker compose --env-file .env.production \
#     -f docker-compose.yml -f docker-compose.production.yml \
#     up --build -d
#
# IMPORTANTE:
#  - Estas senhas são DIDÁTICAS, definidas em código aberto para
#    fins acadêmicos. NUNCA reutilize em produção real.
#  - Em produção real, JWT_SECRET e *_DB_PASSWORD viriam de um
#    secret manager (AWS SM, GCP SM, HashiCorp Vault).
#  - O arquivo .env.production REAL fica fora do Git (.gitignore).
# ============================================================

# ── Identificação do projeto Compose ────────────────────────
COMPOSE_PROJECT_NAME=clinica-production

# ── Porta no host ───────────────────────────────────────────
# Gateway é a ÚNICA entrada pública.
# Em produção real ficaria 8080. Aqui usamos 8085 para não conflitar
# com o wordpress local que já ocupa 8080 nesta máquina.
GATEWAY_HOST_PORT=8085

# ── Portas dos bancos no host (publicadas para inspeção/debug) ─
# Em produção real fora de container, NÃO publicar essas portas.
ADMIN_DB_HOST_PORT=3308
AGENDAMENTO_DB_HOST_PORT=3309
ATENDIMENTO_DB_HOST_PORT=3310

# ── JWT ─────────────────────────────────────────────────────
# Gerado com: openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=GzD1Q6QDyzo/p33xLydYvLNFdVBSLr2ZDuSrMOGmnHJEGICx0bdioMcqTZxcPrT+1mqWPEKPPjhzbmu+YP/EOQ==

# ── JPA ─────────────────────────────────────────────────────
JPA_SHOW_SQL=false

# ── JVM ─────────────────────────────────────────────────────
JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -Djava.security.egd=file:/dev/./urandom

# ── Banco administrativo (container db-administrativo) ──────
ADMIN_DB_URL=jdbc:mysql://db-administrativo:3306/clinica_administrativo?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=America/Sao_Paulo
ADMIN_DB_USER=svc_administrativo
ADMIN_DB_PASSWORD=clinica_administrativo_prod_2026

# ── Banco agendamento (container db-agendamento) ────────────
AGENDAMENTO_DB_URL=jdbc:mysql://db-agendamento:3306/clinica_agendamento?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=America/Sao_Paulo
AGENDAMENTO_DB_USER=svc_agendamento
AGENDAMENTO_DB_PASSWORD=clinica_agendamento_prod_2026

# ── Banco atendimento (container db-atendimento) ────────────
ATENDIMENTO_DB_URL=jdbc:mysql://db-atendimento:3306/clinica_atendimento?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=America/Sao_Paulo
ATENDIMENTO_DB_USER=svc_atendimento
ATENDIMENTO_DB_PASSWORD=clinica_atendimento_prod_2026
