# Normaliza line endings entre Linux/macOS/Windows.
# Texto = LF no repositório; Git converte para o nativo no working tree quando
# necessário. Scripts shell e Dockerfile precisam de LF mesmo no Windows
# (rodam dentro de containers Linux).

* text=auto eol=lf

# Scripts Linux / containers — sempre LF, ignorar autocrlf do Windows.
*.sh        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sql       text eol=lf
Dockerfile  text eol=lf

# Scripts Windows — sempre CRLF.
*.cmd       text eol=crlf
*.bat       text eol=crlf
*.ps1       text eol=crlf

# Binários — não normalizar.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.pdf       binary
*.jar       binary
