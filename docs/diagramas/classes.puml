' AGENDAMENTO  (8082)
' ════════════════════════════════════════════════════════
package "agendamento  :8082  [PASSO 10]" #FFF8F0 {

    enum StatusAgendamento <<planned>> {
        AGENDADO
        CONFIRMADO
        CANCELADO
        REALIZADO
    }

    class AgendamentoEntity <<@Entity, planned>> {
        + Long id
        + Long pacienteId
        + Long medicoId
        + LocalDateTime dataHora
        + StatusAgendamento status
        + String observacoes
        + LocalDateTime createdAt
        + LocalDateTime updatedAt
    }

    interface AgendamentoRepository <<JpaRepository, planned>> {
        + existsByMedicoIdAndDataHoraAndStatusIn(...) : boolean
    }

    class AgendamentoService <<@Service, planned>> {
        + criar(req) : AgendamentoEntity
        + findById(id) : AgendamentoEntity
        + listar() : List<AgendamentoEntity>
        + cancelar(id)
    }

    class AgendamentoController <<@RestController, planned>> {
        + criar(req) : ResponseEntity
        + findById(id) : ResponseEntity
        + listar() : ResponseEntity
        + cancelar(id) : ResponseEntity
    }

    interface AdministrativoClient <<@FeignClient, feign>> {
        + pacienteExiste(id) : ExistsResponse
        + medicoExiste(id) : ExistsResponse
    }

    AgendamentoRepository --> AgendamentoEntity          : persiste
    AgendamentoEntity     --> StatusAgendamento           : tem
    AgendamentoService    --> AgendamentoRepository       : usa
    AgendamentoService    --> AdministrativoClient        : valida via Feign
    AgendamentoService    ..> EntityNotFoundException     : lanca
    AgendamentoService    ..> BusinessException           : lanca
    AgendamentoController --> AgendamentoService          : delega
    AgendamentoController ..> ApiResponse                 : wrappa
}

