            + findById(id) : MedicoEntity
            + save(e) : MedicoEntity
            + update(id, e) : MedicoEntity
            + deleteById(id)
            + existsById(id) : ExistsResponse
        }

        class MedicoController <<@RestController, planned>> {
            + findAll() : ResponseEntity
            + findById(id) : ResponseEntity
            + create(req) : ResponseEntity
            + update(id, req) : ResponseEntity
            + delete(id) : ResponseEntity
            + exists(id) : ResponseEntity
        }

        MedicoRepository --> MedicoEntity             : persiste
        MedicoService    --> MedicoRepository         : usa
        MedicoService    ..> EntityNotFoundException  : lanca
        MedicoController --> MedicoService            : delega
        MedicoController ..> ExistsResponse           : retorna
        MedicoController ..> ApiResponse              : wrappa
    }

    ' ── paciente [PASSO 5] ───────────────────────────────
    package "paciente  [PASSO 5]" {

        class PacienteEntity <<@Entity, planned>> {
            + Long id
            + String nome
            + String email
            + String cpf
            + String telefone
            + LocalDate dataNascimento
            + ConvenioEntity convenio
            + LocalDateTime createdAt
            + LocalDateTime updatedAt
        }

        interface PacienteRepository <<JpaRepository, planned>> {
            + existsByEmail(email) : boolean
            + existsByCpf(cpf) : boolean
        }

        class PacienteService <<@Service, planned>> {
            + findAll() : List<PacienteEntity>
            + findById(id) : PacienteEntity
            + save(e, convenioId) : PacienteEntity
            + update(id, e, convenioId) : PacienteEntity
            + deleteById(id)
            + existsById(id) : ExistsResponse
        }

        class PacienteController <<@RestController, planned>> {
            + findAll() : ResponseEntity
            + findById(id) : ResponseEntity
            + create(req) : ResponseEntity
            + update(id, req) : ResponseEntity
            + delete(id) : ResponseEntity
            + exists(id) : ResponseEntity
        }

        PacienteRepository --> PacienteEntity             : persiste
        PacienteService    --> PacienteRepository         : usa
        PacienteService    ..> EntityNotFoundException    : lanca
        PacienteController --> PacienteService            : delega
        PacienteController ..> ExistsResponse             : retorna
        PacienteController ..> ApiResponse                : wrappa
        PacienteEntity "N" --> "0..1" ConvenioEntity      : convenio FK (LAZY)
    }

    ' ── auth [PASSOs 6-7] ────────────────────────────────
    package "auth  [PASSOs 6-7]" {

        enum Role <<planned>> {
            ADMIN
            RECEPCIONISTA
            MEDICO
            PACIENTE
        }

        class UsuarioEntity <<@Entity, planned>> {
            + Long id
            + String nome
            + String email
            + String senhaHash
            + Role role
            + LocalDateTime createdAt
        }

        interface UsuarioRepository <<JpaRepository, planned>> {
            + findByEmail(email) : Optional<UsuarioEntity>
            + existsByEmail(email) : boolean
        }

        class JwtService <<@Service, planned>> {
            - SecretKey key
            - long expirationMillis
            --
            + generate(usuario) : String
            + extractAllClaims(token) : Claims
            + getExpirationMillis() : long
        }

        class AuthService <<@Service, planned>> {
            - UsuarioRepository repo
            - JwtService jwtService
            - PasswordEncoder encoder
            --
            + login(req) : LoginResponse
            + register(req) : UsuarioResponse
        }

        class AuthController <<@RestController, planned>> {
            + login(req) : ResponseEntity
            + register(req) : ResponseEntity
        }

        class JwtAuthFilter <<Filter, planned>> {
            - JwtService jwtService
            --
            + doFilterInternal(req, res, chain)
        }

        class SecurityConfigJwt <<@Configuration, planned>> {
            + filterChain(http) : SecurityFilterChain
            + passwordEncoder() : PasswordEncoder
            + authProvider() : DaoAuthenticationProvider
        }

        note bottom of SecurityConfigJwt
          Substitui o SecurityConfig
          temporario do PASSO 3.
          Adiciona JWT + BCrypt.
        end note

        UsuarioEntity    --> Role               : tem
        UsuarioRepository --> UsuarioEntity     : persiste
        AuthService      --> UsuarioRepository  : usa
        AuthService      --> JwtService         : gera token
        AuthController   --> AuthService        : delega
        AuthController   ..> ApiResponse        : wrappa
        JwtAuthFilter    --> JwtService         : valida token
        SecurityConfigJwt --> JwtAuthFilter     : registra filtro
    }
}

