' ════════════════════════════════════════════════════════
' COMMONS  (biblioteca tecnica compartilhada)
' ════════════════════════════════════════════════════════
package "commons" #EEF4FB {

    class "ApiResponse<T>" as ApiResponse {
        + boolean success
        + T data
        + String message
        + List<String> errors
        --
        + {static} success(data) : ApiResponse<T>
        + {static} success() : ApiResponse<Void>
        + {static} error(msg) : ApiResponse<T>
        + {static} error(msg, errors) : ApiResponse<T>
    }

    class GlobalExceptionHandler <<@RestControllerAdvice>> {
        + handleEntityNotFound() : 404
        + handleBusiness() : 422
        + handleValidation() : 400
        + handleFeignIntegration() : 502
        + handleGeneral() : 500
    }

    class CommonsAutoConfiguration <<@AutoConfiguration>> {
        + modelMapper() : ModelMapper
        + globalExceptionHandler() : GlobalExceptionHandler
    }

    class EntityNotFoundException {
        + EntityNotFoundException(message)
    }
    class BusinessException {
        + BusinessException(message)
    }
    class FeignIntegrationException {
        + FeignIntegrationException(message)
        + FeignIntegrationException(message, cause)
    }

    EntityNotFoundException   --|> RuntimeException
    BusinessException         --|> RuntimeException
    FeignIntegrationException --|> RuntimeException

    CommonsAutoConfiguration  ..> GlobalExceptionHandler : registra bean
    GlobalExceptionHandler    ..> ApiResponse            : produz
    GlobalExceptionHandler    ..> EntityNotFoundException  : captura 404
    GlobalExceptionHandler    ..> BusinessException        : captura 422
    GlobalExceptionHandler    ..> FeignIntegrationException : captura 502
}

' ════════════════════════════════════════════════════════
' ADMINISTRATIVO  (8081)
' ════════════════════════════════════════════════════════
package "administrativo  :8081" #F1FBF1 {

    ' ── convenio [implementado] ──────────────────────────
    package "convenio  [PASSO 3 - OK]" {

        class ConvenioEntity <<@Entity>> {
            + Long id
            + String nome
            + String descricao
            + LocalDateTime createdAt
            + LocalDateTime updatedAt
            --
            # onCreate()
            # onUpdate()
        }

        interface ConvenioRepository <<JpaRepository>> {
        }

        class ConvenioService <<@Service>> {
            - ConvenioRepository repo
            --
            + findAll() : List<ConvenioEntity>
            + findById(id) : ConvenioEntity
            + save(e) : ConvenioEntity
            + update(id, e) : ConvenioEntity
            + deleteById(id)
        }

        class ConvenioController <<@RestController>> {
            - ConvenioService service
            - ModelMapper mapper
            --
            + findAll() : ResponseEntity
            + findById(id) : ResponseEntity
            + create(req) : ResponseEntity
            + update(id, req) : ResponseEntity
            + delete(id) : ResponseEntity
        }

        class ConvenioRequest <<DTO>> {
            + String nome
            + String descricao
        }

        class ConvenioResponse <<DTO>> {
            + Long id
            + String nome
            + String descricao
            + LocalDateTime createdAt
            + LocalDateTime updatedAt
        }

        class ExistsResponse <<record>> {
            + boolean exists
        }

        ConvenioRepository --> ConvenioEntity         : persiste
        ConvenioService    --> ConvenioRepository     : usa
        ConvenioService    ..> EntityNotFoundException : lanca
        ConvenioController --> ConvenioService        : delega
        ConvenioController ..> ConvenioRequest        : recebe
        ConvenioController ..> ConvenioResponse       : retorna
        ConvenioController ..> ApiResponse            : wrappa
    }

